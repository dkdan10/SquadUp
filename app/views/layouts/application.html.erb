<!DOCTYPE html>
<html>
  <head>
    <title>SquadUp</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://fonts.googleapis.com/css?family=Pacifico&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Permanent+Marker&display=swap" rel="stylesheet">


    <%= javascript_include_tag "https://maps.googleapis.com/maps/api/js?key=#{ENV['GOOGLE_MAPS_API_KEY']}&libraries=places" %>
    <%= stylesheet_link_tag    'application', media: 'all' %>
    <%= javascript_include_tag 'application' %>
    <script src="https://kit.fontawesome.com/caa36ac162.js"></script>


    <% if logged_in? %>
      <script type="application/json" id="bootstrap-current-user">
        <%=raw json_escape(render("api/users/user.json.jbuilder", user: current_user)) %>
      </script>
      <script type="text/javascript">
        window.currentUser = JSON.parse(document.getElementById('bootstrap-current-user').textContent);
      </script>
    <% end %>
    
  </head>

  <body>
  
    <%= yield %>
  </body>
</html>
